# ============================================================
# Monorepo .gitignore
# master = 源码 (site/), gh-pages = 构建产物 (由 CI 自动部署)
# ============================================================

# Dependencies
node_modules/
npm-debug.log
yarn-error.log
yarn.lock

# Hexo generated (intermediate files, not committed to master)
site/public/
site/.deploy_cache/
site/.deploy_git/
site/db.json
site/_debug/

# Build output (deployed to gh-pages branch by GitHub Actions, not tracked here)
public/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Temp files
*.tmp
*.temp
