{
  "name": "wadrn-blog-source",
  "version": "2.0.0",
  "private": true,
  "description": "Doreen's Notes - Hexo blog source (monorepo: site/ = source, public/ = generated)",
  "scripts": {
    "build": "node build.js",
    "clean": "rm -rf ../public db.json",
    "server": "node build.js --server",
    "convert:posts": "node ../scripts/html-to-md.js"
  },
  "hexo": {
    "version": "7.3.0"
  },
  "dependencies": {
    "hexo": "^7.3.0",
    "hexo-generator-archive": "^2.0.0",
    "hexo-generator-category": "^2.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-tag": "^2.0.0",
    "hexo-renderer-marked": "^6.3.0",
    "hexo-renderer-stylus": "^3.0.0",
    "hexo-server": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
